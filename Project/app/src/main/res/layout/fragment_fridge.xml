<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- [구역 1] 최상단 커스텀 툴바 (뒤로가기 + 타이틀) -->
    <RelativeLayout
        android:id="@+id/toolbar_area"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">
        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="←"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:text="냉장고 털기"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- 중간 내용 스크롤 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar_area"
        android:layout_above="@id/btn_search"
        android:fillViewport="true">

        <!-- ★ 부모 레이아웃의 focusable, focusableInTouchMode 속성을 완전히 제거했습니다 -->
        <LinearLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp">

            <!-- [구역 2] 메인 슬로건 문구 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="냉장고 속의 재료"
                        android:textColor="#557733"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="만 입력하시면"
                        android:textColor="#111111"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="최적의 레시피를 추천해 드려요."
                    android:textColor="#111111"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 1. 냉장고 재료 상자 구역 -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="냉장고 재료" android:textColor="#888888" android:textSize="14sp" />
                <TextView android:id="@+id/btn_clear_fridge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:text="전체삭제" android:textColor="#999999" android:textSize="13sp" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/layout_fridge_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="90dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/shape_edittext_fridge_green"
                android:orientation="vertical"
                android:padding="12dp"
                android:clickable="true">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cg_fridge_chips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="6dp" />

                <EditText
                    android:id="@+id/et_fridge_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@null"
                    android:hint="재료를 입력하고 완료를 누르세요"
                    android:textColor="#222222"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:imeOptions="actionDone"
                    android:privateImeOptions="defaultInputmode=korean" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="여러개의 재료 입력시 각 재료는 키보드의 완료/엔터로 구분해 주세요."
                android:textColor="#999999"
                android:textSize="12sp" />

            <!-- 2. 최근 검색어 구역 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="최근 검색어"
                    android:textColor="#888888"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/btn_clear_recent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="전체삭제"
                    android:textColor="#999999"
                    android:textSize="13sp" />
            </RelativeLayout>
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cg_recent_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:chipSpacingHorizontal="6dp"
                app:chipSpacingVertical="6dp" />

            <!-- 3. 제외 재료 상자 구역 -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="제외 재료" android:textColor="#888888" android:textSize="14sp" />
                <TextView android:id="@+id/btn_clear_exclude" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:text="전체삭제" android:textColor="#999999" android:textSize="13sp" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/layout_exclude_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/shape_edittext_fridge_gray"
                android:orientation="vertical"
                android:padding="12dp"
                android:clickable="true">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cg_exclude_chips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="6dp" />

                <EditText
                    android:id="@+id/et_exclude_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:hint="제외할 재료 입력 후 완료"
                    android:textColor="#222222"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:imeOptions="actionDone"
                    android:privateImeOptions="defaultInputmode=korean" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 최하단 고정 검색 버튼 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_search"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="#111111"
        android:text="검색"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</RelativeLayout>