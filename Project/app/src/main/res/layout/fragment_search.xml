<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ======================================================== -->
    <!-- [구역 1] 최상단 검색 헤더 바 (뒤로가기 + 입력창 + 돋보기 + ic_mic2) -->
    <!-- ======================================================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#FFFFFF">

        <!-- 좌측: 뒤로가기 화살표 단추 -->
        <TextView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="←"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <!-- 중앙: 계란형 연회색 검색 입력창 박스 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginLeft="4dp"
            android:background="@drawable/shape_search_background"
            android:backgroundTint="#F2F2F2"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <EditText
                android:id="@+id/et_search_keyword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="요리, 재료 검색"
                android:textColor="#222222"
                android:textColorHint="#999999"
                android:textSize="15sp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1" />
        </LinearLayout>

        <!-- 우측 1: 돋보기 아이콘 버튼 -->
        <ImageView
            android:id="@+id/btn_search_click"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginLeft="14dp"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="검색 실행"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground" />

        <!-- 우측 2: 새 블랙 마이크 아이콘 버튼 (ic_mic2 탑재) -->
        <ImageView
            android:id="@+id/btn_voice_search_click"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginLeft="14dp"
            android:src="@drawable/ic_mic2"
            android:contentDescription="음성 검색"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EFEFEF" />

    <!-- ======================================================== -->
    <!-- [구역 2] 중단 본문: 이미지 2번의 모든 추천 카테고리 뷰 대복구 -->
    <!-- ======================================================== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <!-- 1. 내가 본 분류 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="내가 본 분류"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />
            <View android:layout_width="80dp" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginTop="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginTop="16dp">

                <!-- 밥/죽/떡 아이콘 (ic_rice 매칭) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="16dp">
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_rice"
                        android:scaleType="fitCenter" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="밥/죽/떡"
                        android:textColor="#555555"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- 일상 아이콘 (ic_normal 매칭) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="16dp">
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_normal"
                        android:scaleType="fitCenter" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="일상"
                        android:textColor="#555555"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 2. 추천 태그 칩스 구역 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="추천"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />
            <View android:layout_width="50dp" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginTop="4dp"/>

            <!-- 추천 키워드 칩 플로우 행들 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal" android:layout_marginTop="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="간편요리" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="한끼식사" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="메인요리" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="색다른요리" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="술안주" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="요리초보" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="간단술안주" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="저녁" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="든든한끼" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="맛보장" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>

            <!-- 3. 실시간 검색어 순위 구역 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:text="실시간 검색어"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />
            <View android:layout_width="90dp" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginTop="4dp"/>

            <!-- 실시간 순위 리스트 단추들 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal" android:layout_marginTop="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. 오이무침" android:textColor="#333333" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2. 오이냉국" android:textColor="#333333" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3. 제육볶음" android:textColor="#333333" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp" android:textStyle="bold"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4. 닭볶음탕" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5. 감자전" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6. 가지볶음" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7. 감자조림" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8. 비빔국수" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="9. 옥수수삶는법" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="14dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10. 삼계탕" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="18dp" android:paddingVertical="8dp" android:layout_marginTop="4dp"/>

            <!-- 4. 인기 검색어 가득 찬 태그 클라우드 존 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:text="인기 검색어"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />
            <View android:layout_width="80dp" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginTop="4dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal" android:layout_marginTop="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="오이무침" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="오이냉국" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="닭볶음탕" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="제육볶음" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="가지볶음" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="감자조림" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="감자" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="옥수수삶는법" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="14dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="두부조림" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="감자전" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="오징어볶음" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="비빔국수" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="삼계탕" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="된장찌개" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="김치찌개" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="미역국" android:textColor="#555555" android:background="@drawable/shape_search_background" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_margin="4dp"/></LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>