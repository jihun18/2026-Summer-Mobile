<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="140dp"
    android:layout_height="wrap_content"
    android:layout_marginRight="12dp"
    android:orientation="vertical">

    <!-- 💡 [수정] View를 ImageView로 바꾸고 ID를 ivRecipeImage로 매칭 -->
    <ImageView
        android:id="@+id/ivRecipeImage"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:scaleType="centerCrop"
        android:background="@drawable/shape_recipe_placeholder"
        tools:src="@drawable/ic_chadol" />

    <!-- 1. 레시피 제목 -->
    <TextView
        android:id="@+id/tv_recipe_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="차돌박이 된장찌개 맛나게 끓이는 법"
        android:textColor="#333333"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- 2. 별점 및 평점 -->
    <TextView
        android:id="@+id/tv_recipe_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="★ 4.8 (120)"
        android:textColor="#F2C94C"
        android:textSize="12sp" />

</LinearLayout>