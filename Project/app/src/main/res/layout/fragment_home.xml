<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- [구역 1] 최상단 검색창 + 우측 요리책 아이콘 상자 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp">

            <!-- 통합검색화면 진입용 컨테이너 -->
            <LinearLayout
                android:id="@+id/layout_search_bar_container"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/shape_search_background"
                android:backgroundTint="#F2F2F2"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="요리, 재료 검색"
                    android:textColor="#999999"
                    android:textSize="15sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎤"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginLeft="12dp"
                android:background="@drawable/shape_search_background"
                android:backgroundTint="#F2F2F2"
                android:gravity="center"
                android:text="📖"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- [구역 2] 메인 공모전 배너 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#EFEFEF"
                android:padding="16dp">
                <TextView
                    android:id="@+id/tv_banner_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="제 197회 만개의레시피 공모전"
                    android:textColor="#666666"
                    android:textSize="12sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_banner_tag"
                    android:layout_marginTop="6dp"
                    android:text="우리집만의 밀키트\n레시피를 알려주세요"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:text="🍱"
                    android:textSize="55sp" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- [구역 3] 5대 메인 아이콘 장착 구역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="16dp"
            android:weightSum="5">

            <!-- 1. 오늘 뭐먹지 -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_todayeat" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="오늘\n뭐먹지" android:gravity="center" android:textColor="#333333" android:textSize="12sp" />
            </LinearLayout>

            <!-- 2. 냉장고 털기 -->
            <LinearLayout android:id="@+id/btn_go_fridge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:foreground="?android:attr/selectableItemBackground">
                <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_refrig" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="냉장고\n털기" android:gravity="center" android:textColor="#333333" android:textStyle="bold" android:textSize="12sp" />
            </LinearLayout>

            <!-- 3. 출석 포인트 -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_point" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="출석\n포인트" android:gravity="center" android:textColor="#333333" android:textSize="12sp" />
            </LinearLayout>

            <!-- ★ 4. 장보기 메모 [연동 ID 및 피드백 주입 완료] -->
            <LinearLayout android:id="@+id/btn_go_shopping_memo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:clickable="true" android:focusable="true" android:foreground="?android:attr/selectableItemBackground">
                <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_shopmemo" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="장보기\n메모" android:gravity="center" android:textColor="#333333" android:textStyle="bold" android:textSize="12sp" />
            </LinearLayout>

            <!-- 5. 할인정보 -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_saleinform" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="할인정보" android:gravity="center" android:textColor="#333333" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- [구역 3-1] 전체보기 ∨ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="전체보기 ∨"
            android:textColor="#888888"
            android:textSize="13sp" />

        <!-- [구역 4] 하단 보라색 쿠팡 가격 추적 배너 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#7F66FF"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="자주 사는 쿠팡 상품 최저가로 구매!"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="쿠팡 가격변동 추적 알림앱 설치 ➔"
                        android:textColor="#E0DFFF"
                        android:textSize="11sp" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="🚀"
                    android:textSize="28sp" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- 1. 내가 최근 본 레시피 -->
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="28dp" android:layout_marginHorizontal="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="내가 최근 본 레시피" android:textColor="#222222" android:textSize="17sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_centerInParent="true" android:text="더보기 ➔" android:textColor="#888888" android:textSize="12sp" />
        </RelativeLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recent_recipe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal"
            tools:listitem="@layout/item_recipe_card" />

        <!-- 2. 어제 많이 본 요리 -->
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="28dp" android:layout_marginHorizontal="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="어제 많이 본 요리" android:textColor="#222222" android:textSize="17sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_centerInParent="true" android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&quot;고추장찌개&quot; " android:textColor="#27AE60" android:textStyle="bold" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="더보기 ➔" android:textColor="#888888" android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="고추장찌개" android:textColor="#FFFFFF" android:background="@drawable/shape_search_background" android:backgroundTint="#222222" android:paddingHorizontal="14dp" android:paddingVertical="6dp" android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="오이무침" android:textColor="#555555" android:background="@drawable/shape_search_background" android:layout_marginLeft="8dp" android:paddingHorizontal="14dp" android:paddingVertical="6dp" android:textSize="13sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="감자채볶음" android:textColor="#555555" android:background="@drawable/shape_search_background" android:layout_marginLeft="8dp" android:paddingHorizontal="14dp" android:paddingVertical="6dp" android:textSize="13sp"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_yesterday_recipe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal"
            tools:listitem="@layout/item_recipe_card" />

        <!-- 3. 맛있게 즐기는 옥수수 요리 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="28dp"
            android:layout_marginHorizontal="16dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="맛있게 즐기는 옥수수 요리" android:textColor="#222222" android:textSize="17sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_centerInParent="true" android:text="더보기" android:textColor="#888888" android:textSize="12sp" />
            </RelativeLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="다양하게 즐기는 달콤한 맛" android:textColor="#888888" android:textSize="12sp" />
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_corn_recipe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="16dp"
            tools:listitem="@layout/item_recipe_card" />

        <!-- 4. 공유수로 검증된 레시피 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="28dp"
            android:layout_marginHorizontal="16dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="공유수로 검증된 레시피" android:textColor="#222222" android:textSize="17sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_centerInParent="true" android:text="더보기" android:textColor="#888888" android:textSize="12sp" />
            </RelativeLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="3,000번 이상 공유된 레시피에요" android:textColor="#888888" android:textSize="12sp" />
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sharedRecipe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal"
            tools:listitem="@layout/item_recipe_card" />

        <!-- 5. 최신 요리 후기 -->
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="36dp" android:layout_marginHorizontal="16dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="최신 요리 후기" android:textColor="#222222" android:textSize="17sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="직접 요리 후에 맛보고 남긴 찐후기에요" android:textColor="#888888" android:textSize="12sp" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:text="더보기" android:textColor="#888888" android:textSize="12sp" />
        </RelativeLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginHorizontal="16dp" android:orientation="vertical"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical"><View android:layout_width="26dp" android:layout_height="26dp" android:background="@drawable/shape_circle" android:backgroundTint="#D3A27F"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="어린환자" android:textColor="#333333" android:textStyle="bold" android:textSize="13sp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="6dp" android:text="★ 5.0" android:textColor="#F2C94C" android:textStyle="bold" android:textSize="12sp"/></LinearLayout><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/shape_search_background" android:backgroundTint="#FFFFFF" android:elevation="1dp" android:padding="12dp" android:orientation="horizontal"><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="다이어트 요리 토마토 계란볶음 딱!" android:textColor="#222222" android:textStyle="bold" android:textSize="14sp"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="부드러운 계란에 달큰한 양파와 토마토가 잘 어울리고 먹고 나서 속도..." android:textColor="#666666" android:textSize="13sp" android:maxLines="2" android:ellipsize="end"/></LinearLayout><View android:layout_width="65dp" android:layout_height="65dp" android:layout_marginLeft="12dp" android:background="@drawable/shape_recipe_placeholder"/></LinearLayout></LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginHorizontal="16dp" android:orientation="vertical"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical"><View android:layout_width="26dp" android:layout_height="26dp" android:background="@drawable/shape_circle" android:backgroundTint="#E0E0E0"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="요리검색자" android:textColor="#333333" android:textStyle="bold" android:textSize="13sp"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="6dp" android:text="★ 5.0" android:textColor="#F2C94C" android:textStyle="bold" android:textSize="12sp"/></LinearLayout><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/shape_search_background" android:backgroundTint="#FFFFFF" android:elevation="1dp" android:padding="12dp" android:orientation="horizontal"><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="깻잎찜 만드는 법" android:textColor="#222222" android:textStyle="bold" android:textSize="14sp"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="정확한 계량 and 요리시간 덕분에 성공했어요. 맵찔이라 고춧가루 절반만..." android:textColor="#666666" android:textSize="13sp" android:maxLines="2" android:ellipsize="end"/></LinearLayout><View android:layout_width="65dp" android:layout_height="65dp" android:layout_marginLeft="12dp" android:background="@drawable/shape_recipe_placeholder"/></LinearLayout></LinearLayout>

        <!-- 6. 더 많은 요리 후기 보기 버튼 -->
        <LinearLayout
            android:id="@+id/btn_more_reviews"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/shape_search_background"
            android:backgroundTint="#FFFFFF"
            android:elevation="1dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:foreground="?android:attr/selectableItemBackground">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="더 많은 요리 후기 보기  " android:textColor="#222222" android:textSize="15sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="∨" android:textColor="#222222" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>