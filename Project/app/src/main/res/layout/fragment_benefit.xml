<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- [구역 1] 마이 포인트 카드 대시보드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="마이 포인트"
                        android:textColor="#222222"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:text="🔄"
                        android:textSize="16sp" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="보유 포인트"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 P ➔"
                            android:textColor="#E64A19"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:text="🪙"
                        android:textSize="45sp" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EFEFEF"
                    android:layout_marginVertical="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="오늘 적립 포인트"
                        android:textColor="#666666"
                        android:textSize="13sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 P"
                        android:textColor="#222222"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="다음달 소멸예정 포인트"
                        android:textColor="#666666"
                        android:textSize="13sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 P"
                        android:textColor="#222222"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- [구역 2] 5대 기능 퀵 아이콘 바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:weightSum="5">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical"><TextView android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/shape_search_background" android:backgroundTint="#EBF5FF" android:gravity="center" android:text="📅" android:textSize="20sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="출석포인트" android:textColor="#444444" android:textSize="11sp" android:gravity="center"/></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical"><TextView android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/shape_search_background" android:backgroundTint="#FEEFEE" android:gravity="center" android:text="🅿️" android:textSize="20sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="포인트적립" android:textColor="#444444" android:textSize="11sp" android:gravity="center"/></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical"><TextView android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/shape_search_background" android:backgroundTint="#EBFBFA" android:gravity="center" android:text="🎟️" android:textSize="20sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="쿠폰함" android:textColor="#444444" android:textSize="11sp" android:gravity="center"/></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical"><TextView android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/shape_search_background" android:backgroundTint="#F4F8F0" android:gravity="center" android:text="🏪" android:textSize="20sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="포인트샵" android:textColor="#444444" android:textSize="11sp" android:gravity="center"/></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical"><TextView android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/shape_search_background" android:backgroundTint="#FFF8E7" android:gravity="center" android:text="❓" android:textSize="20sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="FAQ" android:textColor="#444444" android:textSize="11sp" android:gravity="center"/></LinearLayout>
        </LinearLayout>

        <!-- [구역 3] 띠 배너 2종 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FFF9C4" android:paddingHorizontal="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="🛒 coupang 방문하면 10P 지급" android:textColor="#333333" android:textSize="14sp" android:textStyle="bold" /></RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:background="#E8F5E9" android:paddingHorizontal="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="🟢 1,000P ➔ N Pay 1,000원으로 교환" android:textColor="#2E7D32" android:textSize="13sp" android:textStyle="bold" /></RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- [구역 4] 광고보고 포인트 적립 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="광고보고 포인트 적립"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="광고만 봐도 포인트가 척척 쌓여요"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:text="포인트 더 받기 ➔"
                android:textColor="#E64A19"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <androidx.cardview.widget.CardView
                    android:layout_width="220dp"
                    android:layout_height="130dp"
                    android:layout_marginRight="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:background="#EFEBE9" android:padding="16dp"><TextView android:id="@+id/tv_ad1_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="더 쉬워졌어요!\n손바닥 뒤집기" android:textColor="#4E342E" android:textSize="15sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tv_ad1_title" android:layout_marginTop="8dp" android:text="이제 더 쉽게 참여해요!" android:textColor="#8D6E63" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_alignParentBottom="true" android:background="@drawable/shape_search_background" android:backgroundTint="#E64A19" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:text="1 P" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" /></RelativeLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_width="220dp"
                    android:layout_height="130dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:background="#E8EAF6" android:padding="16dp"><TextView android:id="@+id/tv_ad2_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="도전! 미션 수행\n버튼 누르기" android:textColor="#1A237E" android:textSize="15sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tv_ad2_title" android:layout_marginTop="8dp" android:text="버튼만 눌러도 적립 완료" android:textColor="#5C6BC0" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_alignParentBottom="true" android:background="@drawable/shape_search_background" android:backgroundTint="#E64A19" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:text="2 P" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" /></RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- [구역 5] 포인트샵 인기쿠폰 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginHorizontal="16dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="포인트샵 인기쿠폰"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="포인트샵에서 가장 많이 구매하신 쿠폰"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_centerVertical="true" android:text="더보기 ➔" android:textColor="#888888" android:textSize="12sp" />
        </RelativeLayout>

        <!-- 2x2 기프티콘 격자 매칭 박스 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            android:columnCount="2">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:padding="8dp"><View android:layout_width="match_parent" android:layout_height="95dp" android:background="#00C73C"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="네이버페이" android:textColor="#888888" android:textSize="11sp"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="네이버페이 포인트 5,000원" android:textColor="#333333" android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="5,000 P" android:textColor="#E64A19" android:textSize="14sp" android:textStyle="bold"/></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:padding="8dp"><View android:layout_width="match_parent" android:layout_height="95dp" android:background="#E5DCC6"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="신세계" android:textColor="#888888" android:textSize="11sp"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="신세계 상품권(5,000원)" android:textColor="#333333" android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="5,000 P" android:textColor="#E64A19" android:textSize="14sp" android:textStyle="bold"/></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:padding="8dp"><View android:layout_width="match_parent" android:layout_height="95dp" android:background="#E60012"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="다이소" android:textColor="#888888" android:textSize="11sp"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="다이소 모바일 금액권 5,000원" android:textColor="#333333" android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="5,000 P" android:textColor="#E64A19" android:textSize="14sp" android:textStyle="bold"/></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:padding="8dp"><View android:layout_width="match_parent" android:layout_height="95dp" android:background="#00704A"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="스타벅스" android:textColor="#888888" android:textSize="11sp"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="아이스 카페 아메리카노 T" android:textColor="#333333" android:textSize="13sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="4,700 P" android:textColor="#E64A19" android:textSize="14sp" android:textStyle="bold"/></LinearLayout>
        </GridLayout>

        <!-- [구역 6] 진행중인 이벤트 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="진행중인 이벤트" android:textColor="#222222" android:textSize="16sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="이벤트 참여하시고 사은품도 받아가세요" android:textColor="#888888" android:textSize="12sp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:background="#EFEFEF" android:padding="16dp"><TextView android:id="@+id/tv_ev_tag" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="제 197회 만개의레시피 공모전" android:textColor="#666666" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/tv_ev_tag" android:layout_marginTop="4dp" android:text="우리집만의 밀키트\n레시피를 알려주세요" android:textColor="#111111" android:textSize="16sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_centerVertical="true" android:text="🎁" android:textSize="45sp" /></RelativeLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>