<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- [구역 1] 최상단 커스텀 탭 헤더 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical">

        <!-- 전체 탭 버튼 -->
        <RelativeLayout
            android:id="@+id/tab_total"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tv_tab_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="전체(1)"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />
            <View
                android:id="@+id/indicator_total"
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:background="#70A150" />
        </RelativeLayout>

        <!-- 내폴더 탭 버튼 -->
        <RelativeLayout
            android:id="@+id/tab_folder"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tv_tab_folder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="내폴더(2)"
                android:textColor="#888888"
                android:textSize="16sp" />
            <View
                android:id="@+id/indicator_folder"
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:background="#70A150"
                android:visibility="invisible" />
        </RelativeLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EFEFEF" />

    <!-- [구역 2] 컨텐츠 적재용 특수 컨테이너 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- [화면 A] 전체(1) 활성화 상태의 레시피 리스트 레이아웃 -->
        <LinearLayout
            android:id="@+id/layout_scrap_total"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="visible">

            <LinearLayout
                android:id="@+id/layout_onion_recipe"
                android:layout_width="match_parent"
                android:layout_height="121dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_yangpa"
                        android:scaleType="centerCrop" />
                </androidx.cardview.widget.CardView>

                <!-- 우측 설명 메타상자 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="14dp">

                    <TextView
                        android:id="@+id/tv_recipe_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="양파볶음밥"
                        android:textColor="#557733"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_recipe_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_recipe_sub"
                        android:layout_marginTop="2dp"
                        android:lineSpacingExtra="3dp"
                        android:text="다이어트 식단 표에 넣기\n좋은 원팬 양파 볶음밥"
                        android:textColor="#111111"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layout_stars"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_recipe_title"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★ 4.8"
                            android:textColor="#FFB300"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" (4) · 코난"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_eye_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_alignParentBottom="true"
                        android:text="👁️"
                        android:textColor="#888888"
                        android:textSize="15sp" />

                    <!-- ★ [수정] 원본 위치 유지 + 오른쪽 여백(marginRight) 추가로 겹침 방지 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/layout_stars"
                        android:layout_marginTop="6dp"
                        android:layout_marginRight="30dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/shape_chip_gray"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:text="👤 2인분"
                            android:textColor="#555555"
                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="6dp"
                            android:background="@drawable/shape_chip_gray"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:text="⏱️ 10분"
                            android:textColor="#555555"
                            android:textSize="11sp" />
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- [화면 B] 내폴더 -->
        <LinearLayout
            android:id="@+id/layout_scrap_folder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_add_folder"
                    android:layout_width="110dp"
                    android:layout_height="36dp"
                    android:layout_centerHorizontal="true"
                    android:background="#70A150"
                    android:text="새폴더"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EFEFEF" />
            <RelativeLayout android:layout_width="match_parent" android:layout_height="64dp" android:paddingHorizontal="16dp" android:background="#FFFFFF"><TextView android:id="@+id/f_ic1" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:text="📁" android:textSize="24sp" /><TextView android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_toRightOf="@id/f_ic1" android:layout_marginLeft="14dp" android:gravity="center_vertical" android:text="전체 (1)" android:textColor="#222222" android:textSize="15sp" /></RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EFEFEF" android:layout_marginHorizontal="16dp" />
            <RelativeLayout android:layout_width="match_parent" android:layout_height="64dp" android:paddingHorizontal="16dp" android:background="#FFFFFF"><TextView android:id="@+id/f_ic2" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:text="📁" android:textSize="24sp" /><TextView android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_toRightOf="@id/f_ic2" android:layout_marginLeft="14dp" android:gravity="center_vertical" android:text="기본폴더 (0)" android:textColor="#222222" android:textSize="15sp" /><LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_alignParentRight="true" android:orientation="horizontal" android:gravity="center_vertical"><TextView android:layout_width="32dp" android:layout_height="match_parent" android:text="⋮" android:gravity="center" android:textColor="#888888" android:textSize="18sp"/><TextView android:layout_width="32dp" android:layout_height="match_parent" android:text="⇅" android:gravity="center" android:textColor="#888888" android:textSize="16sp"/></LinearLayout></RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EFEFEF" android:layout_marginHorizontal="16dp" />
            <RelativeLayout android:layout_width="match_parent" android:layout_height="64dp" android:paddingHorizontal="16dp" android:background="#FFFFFF"><TextView android:id="@+id/f_ic3" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:text="📁" android:textSize="24sp" /><TextView android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_toRightOf="@id/f_ic3" android:layout_marginLeft="14dp" android:gravity="center_vertical" android:text="한끼 (1)" android:textColor="#222222" android:textSize="15sp" /><LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_alignParentRight="true" android:orientation="horizontal" android:gravity="center_vertical"><TextView android:layout_width="32dp" android:layout_height="match_parent" android:text="⋮" android:gravity="center" android:textColor="#888888" android:textSize="18sp"/><TextView android:layout_width="32dp" android:layout_height="match_parent" android:text="⇅" android:gravity="center" android:textColor="#888888" android:textSize="16sp"/></LinearLayout></RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EFEFEF" android:layout_marginHorizontal="16dp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>